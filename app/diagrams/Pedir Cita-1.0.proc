          <expectedDuration xmi:type="expression:Expression" xmi:id="_fRQMYh4yEfGURfdQCDIpoA" name="dueDateCalculation()" content="// Bonita necesita la duración esperada en milisegundos&#xD;&#xA;long dias = 2L;&#xD;&#xA;long horas = 24L;&#xD;&#xA;long minutos = 60L;&#xD;&#xA;long segundos = 60L;&#xD;&#xA;long milisegundos = 1000L;&#xD;&#xA;&#xD;&#xA;// Multiplicamos todo para obtener el total de milisegundos de esos 2 días&#xD;&#xA;long duracionTotal = dias * horas * minutos * segundos * milisegundos;&#xD;&#xA;&#xD;&#xA;return duracionTotal;" interpreter="GROOVY" type="TYPE_READ_ONLY_SCRIPT" returnType="java.lang.Long" returnTypeFixed="true"/>
