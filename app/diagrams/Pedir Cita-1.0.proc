                <expression xmi:type="expression:Expression" xmi:id="_tzbxSTpyEfGxrNcWTsCkrw" name="obtenerEmailPaciente()" content="def processInstance = apiAccessor.getProcessAPI().getProcessInstance(processInstanceId);&#xD;&#xA;def initiatorId = processInstance.getStartedBy();&#xD;&#xA;return res = apiAccessor.getIdentityAPI().getUserContactData(initiatorId, false).getEmail();&#xD;&#xA;" interpreter="GROOVY" type="TYPE_READ_ONLY_SCRIPT" returnTypeFixed="true">
