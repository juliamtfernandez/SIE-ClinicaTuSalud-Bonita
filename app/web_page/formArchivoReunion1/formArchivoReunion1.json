    "formInput" : {
      "type" : "json",
      "value" : [
        "{\r",
        "  \"comentariosInput\" : \"\"\r",
        "}"
      ],
      "exposed" : false
    },
    "submit_errors_list" : {
      "type" : "expression",
      "value" : [
        "if($data.formOutput && $data.formOutput._submitError && $data.formOutput._submitError.explanations){",
        "\tconst liElements = $data.formOutput._submitError.explanations",
        "\t\t.filter(cause => cause !== null)",
        "\t\t.map(cause => \"<li>\" + cause + \"</li>\")",
        "\t\t.join('');",
        "\tif(liElements){",
        "\t\treturn \"<ul>\" + liElements + \"</ul>\";",
        "\t}",
        "}"
      ],
      "exposed" : false
    },
    "formOutput" : {
      "type" : "expression",
      "value" : [
        "if ($data.reunion && $data.context) {",
        "",
        "    var result = {",
        "        reunionInput: {",
        "            titulo: $data.reunion.titulo !== undefined ? $data.reunion.titulo : null",
        "        },",
        "        comentariosInput: $data.formInput.comentariosInput,",
        "        archivoReunionDocumentInput:null",
        "    };",
        "",
        "    if ($data.context.archivoReunion_ref ",
        "        && $data.context.archivoReunion_ref.newValue ",
        "        && $data.context.archivoReunion_ref.newValue.tempPath) {",
        "",
        "        result.archivoReunionDocumentInput = {",
        "            id: $data.context.archivoReunion_ref.id ",
        "                ? $data.context.archivoReunion_ref.id.toString() ",
        "                : null,",
        "            filename: $data.context.archivoReunion_ref.newValue.filename || null,",
        "            tempPath: $data.context.archivoReunion_ref.newValue.tempPath || null,",
        "            contentType: $data.context.archivoReunion_ref.newValue.contentType || null",
        "        };",
        "    }",
        "",
        "    return result;",
        "}"
      ],
      "exposed" : false
    },
    "context" : {
      "type" : "url",
      "value" : [
        "../API/bpm/userTask/{{taskId}}/context"
      ],
      "exposed" : false
    },
    "reunion" : {
