    "especialidadFormateada" : {
      "type" : "expression",
      "value" : [
        "if ($data.cita && $data.cita.especialidad && $data.especialidades) {\r",
        "    // Buscamos en tu lista JSON cuál coincide con el valor guardado\r",
        "    var coincidencia = $data.especialidades.find(function(item) {\r",
        "        return item.valor === $data.cita.especialidad;\r",
        "    });\r",
        "    \r",
        "    // Si lo encuentra, devuelve el nombre bonito. Si no, devuelve lo que haya.\r",
        "    if (coincidencia) {\r",
        "        return coincidencia.nombre;\r",
        "    } else {\r",
        "        return $data.cita.especialidad;\r",
        "    }\r",
        "}\r",
        "return \"\";"
      ],
      "exposed" : false
    },
    "horarioFormateado" : {
      "type" : "expression",
      "value" : [
        "var horario = $data.cita.horarioPreferencia; \r",
        "\r",
        "var traductor = {\r",
        "    \"mañana\": \"De 9:00 a 14:00\",\r",
        "    \"tarde\": \"De 16:30 a 21:30\"\r",
        "};\r",
        "\r",
        "// Si hay un horario guardado y coincide con nuestro diccionario, lo traduce\r",
        "if (horario && traductor[horario]) {\r",
        "    return traductor[horario];\r",
        "}\r",
        "\r",
        "// Si está vacío o no coincide, devuelve lo que haya\r",
        "return horario || \"\";"
      ],
      "exposed" : false
    },
