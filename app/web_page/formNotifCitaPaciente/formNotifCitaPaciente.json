  "variables" : {
    "task" : {
      "type" : "url",
      "value" : [
        "../API/bpm/userTask/{{taskId}}"
      ],
      "exposed" : false
    },
    "formInput" : {
      "type" : "json",
      "value" : [
        "{\r",
        "  \"solicitaNuevaFechaInput\" : false\r",
        "}"
      ],
      "exposed" : false
    },
    "submit_errors_list" : {
      "type" : "expression",
      "value" : [
        "if($data.formOutput && $data.formOutput._submitError && $data.formOutput._submitError.explanations){",
        "\tconst liElements = $data.formOutput._submitError.explanations",
        "\t\t.filter(cause => cause !== null)",
        "\t\t.map(cause => \"<li>\" + cause + \"</li>\")",
        "\t\t.join('');",
        "\tif(liElements){",
        "\t\treturn \"<ul>\" + liElements + \"</ul>\";",
        "\t}",
        "}"
      ],
      "exposed" : false
    },
    "formOutput" : {
      "type" : "expression",
      "value" : [
        "if( $data.cita ){",
        "    var nuevoEstado = $data.cita.estadoCita;",
        "    ",
        "    if ($data.formInput.solicitaNuevaFechaInput){",
        "        nuevoEstado = \"en revisión\";",
        "    }",
        "    ",
        "\treturn {",
        "\t\t//map cita variable to expected task contract input",
        "\t\tcitaInput: {",
        "\t\t\testadoCita: $data.cita.estadoCita !== undefined ? nuevoEstado : null",
        "\t\t},",
        "\t\tsolicitaNuevaFechaInput: $data.formInput.solicitaNuevaFechaInput",
        "\t}",
        "}"
      ],
      "exposed" : false
    },
    "context" : {
      "type" : "url",
      "value" : [
        "../API/bpm/userTask/{{taskId}}/context"
      ],
      "exposed" : false
    },
    "cita" : {
      "type" : "url",
      "value" : [
        "../{{context.cita_ref.link}}"
      ],
      "exposed" : false
    },
    "taskId" : {
      "type" : "urlparameter",
      "value" : [
        "id"
      ],
      "exposed" : false
    },
    "medicoInfo" : {
      "type" : "url",
      "value" : [
        "../API/identity/user?f=userName={{cita.medico}}"
      ],
      "exposed" : false
    },
    "horarioFormateado" : {
      "type" : "expression",
      "value" : [
        "var horario = $data.cita.horarioPreferencia; \r",
        "\r",
        "var traductor = {\r",
        "    \"mañana\": \"De 9:00 a 14:00\",\r",
        "    \"tarde\": \"De 16:30 a 21:30\"\r",
        "};\r",
        "\r",
        "// Si hay un horario guardado y coincide con nuestro diccionario, lo traduce\r",
        "if (horario && traductor[horario]) {\r",
        "    return traductor[horario];\r",
        "}\r",
        "\r",
        "// Si está vacío o no coincide, devuelve lo que haya\r",
        "return horario || \"\";"
      ],
      "exposed" : false
    },
    "motivoRechazoData" : {
      "type" : "url",
      "value" : [
        "../API/bpm/caseVariable/{{task.caseId}}/motivoRechazoProc"
      ],
      "exposed" : false
    }
